# Cloudflare Pages / Workers compatible _headers file
# Also works with Vercel if you rename to vercel.json headers config

# Hashed assets (JS/CSS chunks) — immutable, cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# HTML — always revalidate to pick up new chunk references
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# 3D model assets — cache 1 week
/assets/models/*
  Cache-Control: public, max-age=604800

# Textures / images — cache 1 week
/assets/textures/*
  Cache-Control: public, max-age=604800

/assets/icons/*
  Cache-Control: public, max-age=604800

# Enable CORS for asset loading from CDN subdomain
/assets/*
  Access-Control-Allow-Origin: *
